# ─────────────────────────────────────────────────────────────────────────────
# gloood.in — environment variables
# Copy this file to `.env.local` for local dev.
# For production, paste these into Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Email (form submissions → surpreet@gloood.in via Google Workspace SMTP) ──
# Requires an App Password from https://myaccount.google.com/apppasswords
# (2FA must be enabled on the sending account first).
# Paste the 16-char App Password below with spaces removed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=surpreet@gloood.in
SMTP_PASSWORD=xxxxxxxxxxxxxxxx
QUOTE_TO_EMAIL=surpreet@gloood.in
QUOTE_FROM_EMAIL=gloood <surpreet@gloood.in>

# ── Spam protection (Cloudflare Turnstile) ──────────────────────────────────
# Create a site at https://dash.cloudflare.com → Turnstile. Domain: gloood.in.
# Without these, the form still submits but is unprotected.
TURNSTILE_SECRET=0xXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0xXXXXXXXXXXXXXXXXXXXXXX

# ── Analytics (Google Tag Manager) ──────────────────────────────────────────
# Create a container at https://tagmanager.google.com for gloood.in.
# Inside GTM, add tags for: GA4, Meta Pixel, LinkedIn Insight Tag.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Rate limiting (Vercel KV / Upstash Redis) — optional ────────────────────
# Install from Vercel → Marketplace → Upstash → create KV store for this project.
# Without them, the site falls back to in-memory rate limiting (per instance).
KV_REST_API_URL=https://xxxxx.upstash.io
KV_REST_API_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Site URL (used in sitemap, OG images, JSON-LD) ──────────────────────────
NEXT_PUBLIC_SITE_URL=https://gloood.in
